# Environment Variables Example
# Copy this file to .env and fill in your configuration

# Telegram Bot Token (Get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Database Path
DATABASE_PATH=data/orders.db

# Images Storage Directory
IMAGES_DIR=data/images

# Admin IDs (optional, for debug notifications, comma separated)
ADMIN_IDS=

# Log Level
LOG_LEVEL=INFO

# ===== Group Forwarding Configuration =====
# Forwarding Rules: Format "source1:target1,source2:target2"
# Example: FORWARD_RULES=-1001234567890:-1009876543210,-1001111111111:-1002222222222
# Note: When someone replies to bot messages in source group, it will be forwarded to target group
FORWARD_RULES=

# Whether to only forward replies to bot messages (true/false)
# true = Only forward replies to bot messages
# false = Forward all reply messages
FORWARD_ONLY_BOT_REPLIES=true

# Forwarding feature whitelist user ID list (comma separated)
# Only whitelist users can use /setforward and /listforward commands
FORWARD_WHITELIST=123456789,987654321

# Whether admins automatically have forwarding permission (true/false)
ADMIN_CAN_FORWARD=true
